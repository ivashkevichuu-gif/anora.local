Options -MultiViews
RewriteEngine On
RewriteBase /

# Let real files and directories pass through
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Pass PHP backend requests directly
RewriteRule ^backend/ - [L]

# Everything else → React index.html
RewriteRule ^ /index.html [L]
