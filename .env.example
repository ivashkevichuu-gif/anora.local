# ══════════════════════════════════════════════════════════════════════════════
# ANORA Platform — Environment Variables
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────────────────
DB_WRITE_HOST=mysql
DB_READ_HOST=mysql
DB_USER=anora
DB_PASS=changeme
DB_NAME=anora

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET=changeme-generate-a-strong-secret

# ── NOWPayments ──────────────────────────────────────────────────────────────
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_API_BASE=https://api.nowpayments.io/v1
NOWPAYMENTS_SANDBOX=true

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── WebSocket ────────────────────────────────────────────────────────────────
WS_PORT=8080

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── OAuth ────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
OAUTH_REDIRECT_URI=https://anora.bet/backend/api/auth/oauth_callback.php
FRONTEND_URL=https://anora.bet

# ── SMTP (для отправки email через mail()) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
