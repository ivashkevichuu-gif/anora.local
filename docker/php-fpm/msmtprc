# msmtp configuration for ANORA platform
# Uses external SMTP relay for sending emails

defaults
auth           on
tls            on
tls_starttls   on
logfile        /var/log/msmtp.log

account        default
host           smtp.gmail.com
port           587
from           noreply@anora.bet
user           YOUR_SMTP_USER
password       YOUR_SMTP_PASSWORD
